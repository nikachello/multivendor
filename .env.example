# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://multistore.ge
NEXT_PUBLIC_ROOT_DOMAIN=multistore.ge

# ── Auth (Better Auth) ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://multistore.ge

# ── Database (Neon) ───────────────────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ── File uploads (UploadThing) ────────────────────────────────────────────────
UPLOADTHING_TOKEN=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Set to orders@multistore.ge after verifying the domain in Resend
EMAIL_FROM=orders@multistore.ge

# ── Google OAuth (Better Auth social provider) ────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://multistore.ge/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
